{
  "permissions": {
    "allow": [
      "mcp__clasi__get_version",
      "mcp__aprilcam__list_cameras",
      "mcp__clasi__list_tickets",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:17439/mcp/sse)",
      "Bash(aprilcam web:*)",
      "Read(//tmp/**)",
      "Read(//private/tmp/**)",
      "mcp__clasi__list_sprints",
      "Bash(find tests:*)",
      "Bash(find src:*)",
      "Bash(find src/aprilcam/cli -name '*.py' -exec sed -i '' -e 's|from \\\\.\\\\.camutil import|from ..camera.camutil import|g' -e 's|from \\\\.\\\\.homography import|from ..calibration.homography import|g' -e 's|from \\\\.\\\\.liveview import|from ..ui.liveview import|g' -e 's|from \\\\.\\\\.mcp_server import|from ..server.mcp_server import|g' -e 's|from \\\\.\\\\.web_server import|from ..server.web_server import|g' '{}' +)",
      "mcp__aprilcam__get_version",
      "mcp__aprilcam__open_camera",
      "Skill(plan-sprint)",
      "Skill(plan-sprint:*)",
      "Skill(execute-sprint)",
      "Skill(execute-sprint:*)",
      "Bash(kill 78648)",
      "Bash(rm /tmp/aprilcam/aprilcamd.pid && uv run aprilcam daemon start)",
      "Skill(se)",
      "Skill(se:*)",
      "Bash(dotconfig version *)",
      "Bash(which dotconfig *)",
      "Read(//Volumes/Proj/proj/code-projects/dotconfig/**)"
    ],
    "additionalDirectories": [
      "/private/tmp/aprilcam"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "clasi hook status-inject"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "clasi hook subagent-start"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "clasi hook subagent-stop"
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "clasi hook task-created"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "clasi hook task-completed"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "clasi hook role-guard"
          }
        ]
      },
      {
        "matcher": "mcp__clasi__create_ticket|mcp__clasi__create_sprint",
        "hooks": [
          {
            "type": "command",
            "command": "clasi hook mcp-guard"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "clasi hook commit-check"
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "clasi hook plan-to-issue"
          }
        ]
      }
    ]
  }
}
