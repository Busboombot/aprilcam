# .aprilcam — project-local AprilCam daemon configuration
#
# This file is an alternative to putting APRILCAM_* keys in .env.
# Use this file when you want daemon settings separate from other
# environment variables. Loading priority (highest wins):
#
#   1. ~/.aprilcam          (user-global, lowest priority)
#   2. .aprilcam            (this file, project-local)
#   3. .env                 (via python-dotenv)
#   4. APRILCAM_* env vars  (process environment, highest priority)
#
# Format: KEY=value, one per line. # comments and blank lines are ignored.
# No quoting — values are used as-is.

# Directory for Unix domain sockets and the pidfile.
# APRILCAM_SOCKET_DIR=/tmp/aprilcam/

# Directory for per-camera runtime data (info.json, paths.json) and daemon log.
# APRILCAM_DATA_DIR=./data/runtime/

# Calibration file read by the daemon and written by `aprilcam calibrate`.
# APRILCAM_CALIBRATION_SOURCE=./data/calibration.json

# Where calibration data is saved (defaults to APRILCAM_CALIBRATION_SOURCE).
# APRILCAM_CALIBRATION_SAVE_PATH=./data/calibration.json

# Python logging level for the daemon (DEBUG, INFO, WARNING, ERROR).
# APRILCAM_LOG_LEVEL=INFO

# Pidfile path (defaults to APRILCAM_SOCKET_DIR/aprilcamd.pid).
# APRILCAM_DAEMON_PIDFILE=/tmp/aprilcam/aprilcamd.pid
